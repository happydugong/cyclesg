<?xml version="1.0" encoding="UTF-8"?>
<kml xmlns="http://www.opengis.net/kml/2.2">
  <Document>
    <name>New PCN on Bikes</name>
    <description><![CDATA[A map where you can see all the information on PCN and temporary on road links between them. Other information are also available. Please explore. <br><br>Please place your comment at https://jnhiew.blogspot.sg/2014/12/cycling-map-in-singapore.html<br><br>If you want to know how to use this map, go to my blog to see how to use it.. https://jnhiew.blogspot.com/p/new-pcn-on-bikes-how-to-use.html<br><br>Jonathan Hiew]]></description>
